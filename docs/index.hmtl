<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AI Agent — Deep Architecture Analysis</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Syne:wght@400;600;700;800&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg: #0b0e14;
    --bg2: #111520;
    --bg3: #181d2b;
    --border: #1f2740;
    --accent: #4f8ef7;
    --accent2: #7ee8b2;
    --accent3: #f7c84f;
    --accent4: #f76f8e;
    --text: #c8d4f0;
    --text-dim: #5e6e99;
    --text-bright: #eef2ff;
    --mono: 'DM Mono', monospace;
    --sans: 'Syne', sans-serif;
    --serif: 'Lora', serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.75;
    overflow-x: hidden;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 80px 48px 64px;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(ellipse 80% 50% at 60% -10%, rgba(79,142,247,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 90% 80%, rgba(126,232,178,0.07) 0%, transparent 60%),
      var(--bg);
  }
  .hero-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: var(--sans);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 800;
    color: var(--text-bright);
    line-height: 1.1;
    max-width: 820px;
    margin-bottom: 20px;
  }
  .hero h1 span { color: var(--accent); }
  .hero-sub {
    font-family: var(--serif);
    font-style: italic;
    color: var(--text-dim);
    font-size: 1.05rem;
    max-width: 600px;
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }
  .badge {
    font-family: var(--mono);
    font-size: 11px;
    padding: 5px 14px;
    border-radius: 3px;
    border: 1px solid;
    letter-spacing: 0.08em;
  }
  .badge-blue { border-color: var(--accent); color: var(--accent); }
  .badge-green { border-color: var(--accent2); color: var(--accent2); }
  .badge-yellow { border-color: var(--accent3); color: var(--accent3); }
  .badge-red { border-color: var(--accent4); color: var(--accent4); }

  /* ── LAYOUT ── */
  .layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 100vh;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    padding: 40px 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }
  .sidebar-section-title {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    text-transform: uppercase;
    padding: 0 24px;
    margin-bottom: 10px;
    margin-top: 28px;
  }
  .sidebar a {
    display: block;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--text-dim);
    text-decoration: none;
    padding: 7px 24px;
    transition: all 0.15s;
    border-left: 2px solid transparent;
  }
  .sidebar a:hover {
    color: var(--accent);
    border-left-color: var(--accent);
    background: rgba(79,142,247,0.06);
  }

  /* ── MAIN CONTENT ── */
  .main {
    padding: 64px 60px;
    max-width: 960px;
  }

  /* ── SECTION ── */
  .section {
    margin-bottom: 80px;
    animation: fadeUp 0.4s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .section-number {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .section h2 {
    font-family: var(--sans);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .section h3 {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent2);
    margin: 28px 0 10px;
    letter-spacing: 0.02em;
  }
  .section p { margin-bottom: 14px; color: var(--text); }
  .section ul, .section ol {
    padding-left: 20px;
    margin-bottom: 14px;
  }
  .section li { margin-bottom: 8px; }

  /* ── CODE BLOCK ── */
  pre {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 16px 0 24px;
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.65;
    color: #a8c0e8;
  }
  code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: rgba(79,142,247,0.12);
    color: var(--accent);
    padding: 2px 7px;
    border-radius: 3px;
  }
  pre code { background: none; color: inherit; padding: 0; font-size: inherit; }

  /* ── CALLOUT ── */
  .callout {
    border-left: 3px solid var(--accent);
    background: rgba(79,142,247,0.06);
    padding: 16px 20px;
    margin: 20px 0;
    border-radius: 0 6px 6px 0;
  }
  .callout.warn { border-color: var(--accent3); background: rgba(247,200,79,0.06); }
  .callout.danger { border-color: var(--accent4); background: rgba(247,111,142,0.06); }
  .callout.success { border-color: var(--accent2); background: rgba(126,232,178,0.06); }
  .callout-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 6px;
    color: var(--accent);
  }
  .callout.warn .callout-label { color: var(--accent3); }
  .callout.danger .callout-label { color: var(--accent4); }
  .callout.success .callout-label { color: var(--accent2); }

  /* ── TABLE ── */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0 24px;
    font-family: var(--mono);
    font-size: 12.5px;
  }
  th {
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 10px 14px;
    text-align: left;
    color: var(--accent2);
    font-weight: 500;
    letter-spacing: 0.05em;
  }
  td {
    border: 1px solid var(--border);
    padding: 9px 14px;
    color: var(--text);
  }
  tr:nth-child(even) td { background: rgba(255,255,255,0.018); }

  /* ── FLOW DIAGRAM ── */
  .flow {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 24px 0;
    max-width: 560px;
  }
  .flow-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .flow-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 36px;
  }
  .flow-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .flow-dot.green { background: var(--accent2); box-shadow: 0 0 0 2px var(--accent2); }
  .flow-dot.yellow { background: var(--accent3); box-shadow: 0 0 0 2px var(--accent3); }
  .flow-dot.red { background: var(--accent4); box-shadow: 0 0 0 2px var(--accent4); }
  .flow-connector {
    width: 2px;
    flex: 1;
    background: var(--border);
    min-height: 28px;
    margin: 2px 0;
  }
  .flow-content {
    padding-bottom: 28px;
  }
  .flow-title {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 3px;
  }
  .flow-desc {
    font-family: var(--serif);
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ── ARCH GRID ── */
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
    margin: 20px 0;
  }
  .arch-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px 16px;
    transition: border-color 0.15s;
  }
  .arch-card:hover { border-color: var(--accent); }
  .arch-card-icon {
    font-size: 22px;
    margin-bottom: 8px;
  }
  .arch-card-name {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent2);
    letter-spacing: 0.08em;
    margin-bottom: 6px;
    text-transform: uppercase;
  }
  .arch-card-desc {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    font-family: var(--sans);
  }

  /* ── AGENT LOOP ── */
  .loop-diagram {
    position: relative;
    margin: 32px auto;
    width: 360px;
    height: 360px;
  }
  .loop-center {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 110px; height: 110px;
    border-radius: 50%;
    background: var(--bg3);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    box-shadow: 0 0 32px rgba(79,142,247,0.2);
    z-index: 2;
  }
  .loop-node {
    position: absolute;
    width: 90px; height: 90px;
    border-radius: 12px;
    background: var(--bg3);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    gap: 4px;
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 600;
    transition: border-color 0.2s;
  }
  .loop-node:hover { border-color: var(--accent); }
  .loop-node .icon { font-size: 20px; }
  .loop-node.n1 { top: 8px; left: 50%; transform: translateX(-50%); color: var(--accent); border-color: rgba(79,142,247,0.4); }
  .loop-node.n2 { top: 50%; right: 8px; transform: translateY(-50%); color: var(--accent3); border-color: rgba(247,200,79,0.4); }
  .loop-node.n3 { bottom: 8px; left: 50%; transform: translateX(-50%); color: var(--accent2); border-color: rgba(126,232,178,0.4); }
  .loop-node.n4 { top: 50%; left: 8px; transform: translateY(-50%); color: var(--accent4); border-color: rgba(247,111,142,0.4); }

  /* ── PROBLEM BADGE ── */
  .problem-list { display: flex; flex-direction: column; gap: 12px; margin: 16px 0; }
  .problem-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }
  .problem-severity {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sev-high { background: rgba(247,111,142,0.15); color: var(--accent4); border: 1px solid rgba(247,111,142,0.3); }
  .sev-med { background: rgba(247,200,79,0.12); color: var(--accent3); border: 1px solid rgba(247,200,79,0.3); }
  .sev-low { background: rgba(79,142,247,0.1); color: var(--accent); border: 1px solid rgba(79,142,247,0.3); }
  .problem-text {
    font-family: var(--sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--text);
  }
  .problem-text strong { color: var(--text-bright); }

  /* ── IMPROVEMENT CARDS ── */
  .improve-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 16px 0; }
  .improve-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
  }
  .improve-card h4 {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 700;
    color: var(--accent2);
    margin-bottom: 7px;
    letter-spacing: 0.04em;
  }
  .improve-card p {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    margin: 0;
  }

  /* ── SVG ARCHITECTURE DIAGRAM ── */
  .diagram-wrap {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    margin: 24px 0;
    overflow-x: auto;
  }
  svg text { font-family: 'DM Mono', monospace; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg2); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 32px 60px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 0.06em;
    margin-left: 220px;
  }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { display: none; }
    .main { padding: 32px 24px; }
    footer { margin-left: 0; }
    .improve-grid { grid-template-columns: 1fr; }
    .loop-diagram { width: 280px; height: 280px; }
  }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-tag">// Repository Deep Dive · huynguyenjv/ai-agent</div>
