# =============================================================================
# AI AGENT — PRODUCTION CONFIGURATION
# =============================================================================
# Usage:  docker-compose --env-file .env.prd up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Qdrant Configuration (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=java_codebase

# -----------------------------------------------------------------------------
# vLLM Configuration (LLM Server)
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
VLLM_API_KEY=token-abc123
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_UTIL=0.90
VLLM_MAX_NUM_SEQS=32

# -----------------------------------------------------------------------------
# Embedding Model (ONNX Runtime — no PyTorch needed)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2-onnx
SENTENCE_TRANSFORMERS_HOME=./models

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=WARNING
DEBUG=false

# -----------------------------------------------------------------------------
# Worker & Performance
# -----------------------------------------------------------------------------
MAX_WORKERS=8

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Restrict CORS to your actual frontend domain(s) in production
CORS_ORIGINS=https://your-app.company.com
DISABLE_SSL_VERIFY=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60
REQUEST_TIMEOUT=300

# =============================================================================
# MEMORY BACKEND
# =============================================================================
MEMORY_BACKEND=redis

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-production
REDIS_DB=0
REDIS_MAXMEMORY=512mb
