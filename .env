# =============================================================================
# AI Coding Agent — Development Configuration
# =============================================================================
# Section 17 of the implementation plan.
# =============================================================================

# --- Cloud VM Server ---
API_KEY=dev-secret-key
QDRANT_URL=http://127.0.0.1:6333
# WSL port forward binds 127.0.0.1 inside WSL — use WSL IP from Windows
# Run `wsl hostname -I` to get current WSL IP if this stops working
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# --- Offline Mode (avoid SSL errors behind corporate proxy) ---
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# --- MCP Server (Client Machine) ---
# Set these in Continue's mcpServers[].env
# SERVER_URL=https://myvm.example.com
# REPO_PATH=/path/to/your/project
# TOKEN_BUDGET=8000
# DEPTH_DEFAULT=2
