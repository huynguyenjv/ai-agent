# =============================================================================
# AI AGENT — DEVELOPMENT CONFIGURATION
# =============================================================================
# File này dùng cho local dev.  Production dùng .env.prd:
#   docker-compose --env-file .env.prd up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Qdrant Configuration (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=java_codebase

# -----------------------------------------------------------------------------
# vLLM Configuration (LLM Server)
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
VLLM_API_KEY=token-abc123
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_UTIL=0.85
VLLM_MAX_NUM_SEQS=16

# -----------------------------------------------------------------------------
# Embedding Model (ONNX Runtime — no PyTorch needed)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2-onnx
SENTENCE_TRANSFORMERS_HOME=./models

# -----------------------------------------------------------------------------
# Java Repository Path (for indexing)
# -----------------------------------------------------------------------------
JAVA_REPO_PATH=C:\Users\huynmb\IdeaProjects\source\services\vtrip.core.iam

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO
DEBUG=false

# -----------------------------------------------------------------------------
# Worker & Performance
# -----------------------------------------------------------------------------
MAX_WORKERS=4

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# CORS origins (comma-separated, use * for development)
CORS_ORIGINS=*
# SSL verification (set to true only for corporate proxy issues)
DISABLE_SSL_VERIFY=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
REQUEST_TIMEOUT=300

# =============================================================================
# MEMORY BACKEND (Long-Lived Agent Pattern)
# =============================================================================
# Options: "memory" (development) or "redis" (production)
MEMORY_BACKEND=memory

# -----------------------------------------------------------------------------
# Redis Configuration (required if MEMORY_BACKEND=redis)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAXMEMORY=256mb

# =============================================================================
# CORPORATE PROXY SETTINGS (uncomment nếu cần)
# =============================================================================
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,qdrant,redis

