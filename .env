# Qdrant Configuration (chạy qua docker-compose up -d qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=java_codebase

# vLLM Configuration (server đã forward port về localhost:8000)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
VLLM_API_KEY=token-abc123

# Embedding Model
# Dùng model từ HuggingFace (cần internet)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Hoặc dùng local path nếu đã download
# EMBEDDING_MODEL=./models/all-MiniLM-L6-v2

# Java Repository Path (for indexing)
JAVA_REPO_PATH=/path/to/your/java/repo

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Logging
LOG_LEVEL=INFO

# Debug mode (set to true for auto-reload)
DEBUG=false

# =============================================================================
# CORPORATE PROXY SETTINGS (uncomment và điền nếu cần)
# =============================================================================
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,qdrant

# Bypass SSL verification (đã enable mặc định trong code)
# HF_HUB_DISABLE_SSL_VERIFY=1

