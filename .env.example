# =============================================================================
# AI Coding Agent — DEPLOY .env (Ubuntu + docker compose)
# =============================================================================
# Usage:
#   cp .env.deploy .env
#   # Điền các mục [REQUIRED] + kiểm tra [CHECK]
#   docker compose up -d
#
# Legend:
#   [REQUIRED] — phải set trước khi chạy
#   [CHECK]    — có default, xem lại cho đúng môi trường
#   [OPT]      — tuỳ chọn
# =============================================================================


# ---- Server (ai-agent container) ----------------------------------------
# [REQUIRED] API key cho mọi request /review/pr, /v1/chat/completions, /index
#   Sinh bằng: openssl rand -hex 32
API_KEY=CHANGE_ME_openssl_rand_hex_32

# [CHECK] Bind address trong container — để 0.0.0.0
HOST=0.0.0.0

# [CHECK] Port nội bộ container; compose map ${PORT}:${PORT} ra host
PORT=8080

# [CHECK] INFO cho prod, DEBUG khi troubleshoot
LOG_LEVEL=INFO

# [CHECK] json → log structured (khuyến nghị cho prod/ELK); text cho dev
LOG_FORMAT=json

# [REQUIRED] Restrict CORS. Comma-separated. KHÔNG để "*" ở prod.
#   Ví dụ: https://gitlab.yourcorp.com,https://ide.yourcorp.com
CORS_ORIGINS=*


# ---- vLLM (external) ----------------------------------------------------
# [REQUIRED] URL tới vLLM đã chạy sẵn (image riêng).
#   - vLLM trên cùng host (bare-metal / docker host network):
#       http://host.docker.internal:8000/v1
#   - vLLM ở container khác, cùng docker network:
#       http://<vllm-container-name>:8000/v1
#   - vLLM ở host khác:
#       http://10.x.x.x:8000/v1  hoặc  https://vllm.internal/v1
VLLM_BASE_URL=http://host.docker.internal:8000/v1

# [REQUIRED] Model đang serve trên vLLM. Phải match --served-model-name bên vLLM.
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507-FP8


# ---- RAG feature flag ---------------------------------------------------
# [CHECK] false = bypass rag_search/plan_steps nodes, chat flow đi thẳng generate.
#         Bật lại khi RAG design mới ship.
ENABLE_RAG=false


# ---- Qdrant (compose service) -------------------------------------------
# [CHECK] Giữ nguyên — "qdrant" là service name trong docker-compose.yml
QDRANT_URL=http://qdrant:6333


# ---- HuggingFace cache (cho Embedder: all-MiniLM-L6-v2) ------------------
# [CHECK] LẦN ĐẦU deploy: để =0 để container tải model (~90MB) 1 lần vào volume hf_cache.
#         Sau khi log báo "Embedder initialized.": đổi cả 2 sang =1 rồi `docker compose up -d`.
#         Nếu server không có internet: pre-load cache bằng `docker compose run ...` từ máy có net.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0


# ---- Code Review — GitLab -----------------------------------------------
# [REQUIRED] GitLab base URL (có trailing slash OK, code .rstrip('/') rồi)
GITLAB_URL=https://gitlab.vinit.tech/

# [REQUIRED] Personal/Project Access Token với scope: api (read+write notes & discussions on MRs)
#   Tạo tại: GitLab → User Settings → Access Tokens → scopes: api
#   ⚠️ KHÔNG commit vào git. File này đã nằm trong .gitignore.
GITLAB_TOKEN=
# [OPT] SSL verify cho GitLab:
#   - để trống  → dùng system CA (prod chuẩn)
#   - path      → CA bundle custom, ví dụ /certs/ca.crt
#                 (mount vào container qua ./deploy/certs/ca.crt)
#   - "false"   → tắt verify (CHỈ dev, có warning)
GITLAB_CA_BUNDLE=

# [CHECK] HTTP timeout giây cho mọi call GitLab
GITLAB_HTTP_TIMEOUT=30

# [CHECK] Marker để upsert comment summary in-place (đừng đổi sau khi đã deploy)
AI_REVIEWER_MARKER=AI_REVIEW_MARKER:v1

# [CHECK] Marker cho inline discussions (dùng để resolve thread cũ ở lần review sau)
AI_REVIEWER_INLINE_MARKER=AI_REVIEW_INLINE:v1

# [CHECK] Số lượng review cũ giữ trong <details>Previous reviews</details>
AI_REVIEWER_KEEP_HISTORY=3


# ---- Review limits ------------------------------------------------------
# [CHECK] Timeout tổng cho 1 request /review/pr (giây). Quá hạn trả 504.
REVIEW_TIMEOUT_SECS=180

# [CHECK] Timeout 1 lần gọi vLLM (giây)
REVIEW_LLM_TIMEOUT_SECS=60

# [CHECK] Max tokens output của vLLM mỗi file
REVIEW_LLM_MAX_TOKENS=4096

# [CHECK] Max ký tự diff đưa vào LLM mỗi file (truncate inline, không skip)
REVIEW_MAX_DIFF_CHARS_PER_FILE=40000
